{
  "name": "react-fcm-playground",
  "description": "A playground for Firebase Cloud Messaging (FCM) with React",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "engines": {
    "node": ">= 24.14.1",
    "pnpm": ">=10.6.3"
  },
  "scripts": {
    "dev": "ENV=local pnpm run prebuild:env && vite",
    "prebuild": "./prebuild.sh",
    "prebuild:env": "dotenvx run -f .env.$ENV -- bash ./prebuild.sh",
    "build": "tsc -b && vite build",
    "build:env": "tsc -b && vite build",
    "lint": "eslint .",
    "prettier:fix": "prettier --write \"**/*.{js,jsx,mjs,ts,tsx,css,scss,md,json}\"",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.19.2",
    "@emotion/react": "^11.14.0",
    "firebase": "^12.12.1",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.58.0",
    "react-icons": "^5.5.0",
    "react-syntax-highlighter": "^15.6.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@dotenvx/dotenvx": "^1.44.1",
    "@eslint/js": "^9.34.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "resize-observer-polyfill": "^1.5.1",
    "sass": "^1.98.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
